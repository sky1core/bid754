package bid754

import (
	"fmt"
	"strconv"
	"strings"
)

func executeDecTestScaleBOperation(tc decTestCase, testType string) (decTestExecResult, error) {
	if normalizeDecTestOperation(tc.Operation) != "scaleb" {
		return decTestExecResult{}, fmt.Errorf("%w: %s", errUnsupportedDecTestOperation, tc.Operation)
	}
	if len(tc.Operands) != 2 {
		return decTestExecResult{}, fmt.Errorf("%s requires 2 operands, got %d", tc.Operation, len(tc.Operands))
	}
	if decTestOperandString(tc.Operands[0]) == "#" || decTestOperandString(tc.Operands[1]) == "#" {
		return decTestExecResult{Result: "NaN", Flags: FlagInvalidOperation}, nil
	}
	if result, flags, ok := selectDecTestScaleBNaNResult(tc); ok {
		return decTestExecResult{Result: result, Flags: flags}, nil
	}

	exponent, ok := parseDecTestScaleBExponent(tc.Operands[1], tc)
	if !ok {
		return decTestExecResult{Result: "NaN", Flags: FlagInvalidOperation}, nil
	}

	switch testType {
	case "decimal32":
		a, err := NewDecimal32BIDDirect(decTestOperandString(tc.Operands[0]))
		if err != nil {
			return decTestExecResult{}, err
		}
		result, flags := a.ScaleB(exponent)
		return decTestExecResult{Result: result.String(), Flags: decTestScaleBFlags(tc, result.String(), flags, result.Class())}, nil
	case "decimal64":
		a, err := NewDecimal64BIDDirect(decTestOperandString(tc.Operands[0]))
		if err != nil {
			return decTestExecResult{}, err
		}
		result, flags := a.ScaleB(exponent)
		return decTestExecResult{Result: result.String(), Flags: decTestScaleBFlags(tc, result.String(), flags, result.Class())}, nil
	case "decimal128":
		a, err := NewDecimal128BIDDirect(decTestOperandString(tc.Operands[0]))
		if err != nil {
			return decTestExecResult{}, err
		}
		result, flags := a.ScaleB(exponent)
		return decTestExecResult{Result: result.String(), Flags: decTestScaleBFlags(tc, result.String(), flags, result.Class())}, nil
	default:
		return decTestExecResult{}, fmt.Errorf("%w: %s", errUnsupportedDecTestOperation, tc.Operation)
	}
}

func selectDecTestScaleBNaNResult(tc decTestCase) (string, ExceptionFlags, bool) {
	left, leftOK := parseComparableDecimal(tc.Operands[0])
	right, rightOK := parseComparableDecimal(tc.Operands[1])
	if !leftOK || !rightOK {
		return "", 0, false
	}

	if left.special == decTestSpecialSignalingNaN {
		return formatQuietNaNResult(left.nanSign, left.payload), FlagInvalidOperation, true
	}
	if right.special == decTestSpecialSignalingNaN {
		return formatQuietNaNResult(right.nanSign, right.payload), FlagInvalidOperation, true
	}
	if left.special == decTestSpecialQuietNaN {
		return formatQuietNaNResult(left.nanSign, left.payload), 0, true
	}
	if right.special == decTestSpecialQuietNaN {
		return formatQuietNaNResult(right.nanSign, right.payload), 0, true
	}
	return "", 0, false
}

func parseDecTestScaleBExponent(input string, tc decTestCase) (int, bool) {
	trimmed := strings.TrimSpace(strings.Trim(decTestOperandString(input), "'\""))
	if trimmed == "" {
		return 0, false
	}
	parsed, ok := parseComparableDecimal(trimmed)
	if !ok || parsed.special != decTestSpecialNone || parsed.isZero && strings.ContainsAny(trimmed, ".Ee") {
		return 0, false
	}
	if strings.ContainsAny(trimmed, ".Ee") {
		return 0, false
	}

	value, err := strconv.Atoi(trimmed)
	if err != nil {
		return 0, false
	}
	limit := 2 * (tc.MaxExponent + tc.Precision)
	if value > limit || value < -limit {
		return 0, false
	}
	return value, true
}

func decTestScaleBFlags(tc decTestCase, result string, flags ExceptionFlags, class DecimalClass) ExceptionFlags {
	if flags&FlagInexact != 0 {
		flags |= FlagRounded
	}
	flags = decTestFlagsWithSubnormalClass(flags, class)
	if flags&FlagUnderflow != 0 {
		flags |= FlagSubnormal
		if tc.Clamp == 1 && decTestFiniteResultIsZero(result) {
			flags |= FlagClamped
		}
	}
	return flags
}
