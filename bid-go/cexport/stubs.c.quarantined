BID_UINT128 __bid128_fmod(BID_UINT128 x, BID_UINT128 y) { BID_UINT128 r = {0}; return r; }
BID_UINT128 __bid128_frexp(BID_UINT128 x, int *y) { BID_UINT128 r = {0}; *y = 0; return r; }
BID_UINT128 __bid128_from_int32(int x) { BID_UINT128 r = {0}; return r; }
BID_UINT128 __bid128_from_int64(int64_t x) { BID_UINT128 r = {0}; return r; }
BID_UINT128 __bid128_from_string(const char *s) {
    BID_UINT128 r = {0};
    if (!s) return r;
    while (*s == ' ' || *s == '\t' || *s == '\n' || *s == '\r') s++;
    if (strcmp(s, "inf") == 0 || strcmp(s, "+inf") == 0 ||
        strcmp(s, "Infinity") == 0 || strcmp(s, "+Infinity") == 0) {
        r.w[1] = 0x7800000000000000ull;
        return r;
    }
    if (strcmp(s, "-inf") == 0 || strcmp(s, "-Infinity") == 0) {
        r.w[1] = 0xf800000000000000ull;
        return r;
    }
    if (strcmp(s, "nan") == 0 || strcmp(s, "+nan") == 0) {
        r.w[1] = 0x7c00000000000000ull;
        return r;
    }
    if (strcmp(s, "-nan") == 0) {
        r.w[1] = 0xfc00000000000000ull;
        return r;
    }
    if (strcmp(s, "snan") == 0 || strcmp(s, "+snan") == 0) {
        r.w[1] = 0x7e00000000000000ull;
        return r;
    }
    if (strcmp(s, "-snan") == 0) {
        r.w[1] = 0xfe00000000000000ull;
        return r;
    }
    return r;
}
