// stubs.c - legacy C ABI compatibility state and placeholders
// This file provides:
// 1. Global rounding mode and flags variables
// 2. Historical link placeholders for symbols not exported by this legacy C ABI
//
// This file is not part of the regular generated readtest verification path and
// must not be used as evidence that public Go stubs are acceptable.

#include <stdint.h>
#include <stdlib.h>
#include <string.h>
#include <wchar.h>
#include <math.h>
#include <fenv.h>

// Intel BID compatible types
typedef uint64_t BID_UINT64;
typedef uint32_t BID_UINT32;
typedef struct { uint64_t w[2]; } BID_UINT128;
typedef unsigned int _IDEC_flags;
typedef unsigned int _IDEC_round;

extern _IDEC_round __bid_IDEC_glbround;
extern _IDEC_flags __bid_IDEC_glbflags;

// Implemented in Go (main.go)
extern void __bid64_to_string(char *ps, BID_UINT64 x);

static int bid_set_binary_rounding_from_decimal(void) {
    int old = fegetround();
    switch (__bid_IDEC_glbround) {
    case 0: // BID_ROUNDING_TO_NEAREST
    case 4: // BID_ROUNDING_TIES_AWAY (no direct binary mode)
        fesetround(FE_TONEAREST);
        break;
    case 1: // BID_ROUNDING_DOWN
        fesetround(FE_DOWNWARD);
        break;
    case 2: // BID_ROUNDING_UP
        fesetround(FE_UPWARD);
        break;
    case 3: // BID_ROUNDING_TO_ZERO
        fesetround(FE_TOWARDZERO);
        break;
    default:
        fesetround(FE_TONEAREST);
        break;
    }
    return old;
}

static void bid_restore_binary_rounding(int old) {
    if (old != -1) {
        fesetround(old);
    }
}

static double bid64_to_double_via_string(BID_UINT64 x) {
    char s[128];
    __bid64_to_string(s, x);
    if (strstr(s, "SNaN") || strstr(s, "NaN")) {
        return NAN;
    }
    if (strstr(s, "Inf")) {
        return s[0] == '-' ? -INFINITY : INFINITY;
    }
    return strtod(s, NULL);
}

static long double bid64_to_long_double_via_string(BID_UINT64 x) {
    char s[128];
    __bid64_to_string(s, x);
    if (strstr(s, "SNaN") || strstr(s, "NaN")) {
        return NAN;
    }
    if (strstr(s, "Inf")) {
        return s[0] == '-' ? -INFINITY : INFINITY;
    }
    return strtold(s, NULL);
}

// ============ GLOBAL STATE ============

_IDEC_round __bid_IDEC_glbround = 0;
_IDEC_flags __bid_IDEC_glbflags = 0;

int __bid_getDecimalRoundingDirection(void) { return __bid_IDEC_glbround; }
void __bid_setDecimalRoundingDirection(int r) { __bid_IDEC_glbround = r; }
void __bid_lowerFlags(_IDEC_flags f) { __bid_IDEC_glbflags &= ~f; }
void __bid_restoreFlags(_IDEC_flags f, _IDEC_flags m) { __bid_IDEC_glbflags = (f & m) | (__bid_IDEC_glbflags & ~m); }
_IDEC_flags __bid_saveFlags(_IDEC_flags m) { return __bid_IDEC_glbflags & m; }
void __bid_signalException(_IDEC_flags f) { __bid_IDEC_glbflags |= f; }
_IDEC_flags __bid_testFlags(_IDEC_flags m) { return __bid_IDEC_glbflags & m; }
_IDEC_flags __bid_testSavedFlags(_IDEC_flags s, _IDEC_flags m) { return s & m; }

