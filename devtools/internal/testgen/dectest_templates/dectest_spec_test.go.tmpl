package bid754

import (
	"fmt"
	"path/filepath"
	"runtime"
	"sync"

	"github.com/sky1core/bid754/bid754-go/internal/testspec"
)

var (
	generatedTestSpecOnce sync.Once
	generatedSuiteSpec    testspec.SharedSpec
	generatedTestSpecErr  error
)

func loadGeneratedTestSpec() (testspec.SharedSpec, error) {
	generatedTestSpecOnce.Do(func() {
		_, currentFile, _, ok := runtime.Caller(0)
		if !ok {
			generatedTestSpecErr = fmt.Errorf("resolve dectest_spec_test.go path")
			return
		}
		path := filepath.Join(filepath.Dir(currentFile), "..", "devtools", "generated", "testspec", "spec_index.json")
		spec, err := testspec.LoadGenerated(path)
		if err != nil {
			generatedTestSpecErr = fmt.Errorf("load generated test spec %q: %w", path, err)
			return
		}
		generatedSuiteSpec = spec
	})

	return generatedSuiteSpec, generatedTestSpecErr
}
